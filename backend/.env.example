APP_NAME="Office Gym Nutrition Planner"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# MySQL Database (Hostinger provides this)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nutrition_tracker
DB_USERNAME=root
DB_PASSWORD=

# JWT Authentication
JWT_SECRET=
# Generated by: php artisan jwt:secret

# Google Gemini AI
GEMINI_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Queue (database = uses MySQL jobs table, no Redis needed)
QUEUE_CONNECTION=database

# Admin seed credentials
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin@123

# Cache (database driver works on shared hosting)
CACHE_STORE=database

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug
